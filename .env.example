# ─────────────────────────────────────────────────────────────────────────────
# Market Bubble Live — environment template. Copy to .env.local and fill in.
# Any missing platform keys are fine: that source just shows as "unavailable".
# ─────────────────────────────────────────────────────────────────────────────

PORT=3000

# ── Channels (point at any live channels for testing) ───────────────────────
TWITCH_CHANNEL_BANKS=clix
TWITCH_CHANNEL_ANSEM=ansem
KICK_SLUG_BANKS=fazebanks
KICK_SLUG_ANSEM=ansem
X_HANDLE_BANKS=Banks
X_HANDLE_ANSEM=blknoiz06

# ── Twitch app — https://dev.twitch.tv/console/apps ─────────────────────────
# Used for: viewer counts + live status (app token). Chat reading needs no keys.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ── Kick app — https://kick.com/settings/developer ──────────────────────────
# Used for: viewer counts/ids (app token). Chat reading needs no keys.
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# ── Kick chat read path (unofficial Pusher; constants rarely change) ────────
KICK_PUSHER_KEY=32cbd69e4b950bf97679
KICK_PUSHER_CLUSTER=us2
# Optional: hardcode chatroom ids if Cloudflare blocks server-side slug lookups.
KICK_CHATROOM_ID_BANKS=
KICK_CHATROOM_ID_ANSEM=

# ── X live-chat reader (EXPERIMENTAL, owner-only, default OFF) ───────────────
# No public API exists. To try it, set X_ENABLED=1 and paste the OWNER account's
# own session cookies.
X_ENABLED=0
X_AUTH_TOKEN=
X_CT0=
X_BEARER=
X_BROADCAST_ID_BANKS=
X_BROADCAST_ID_ANSEM=

# ── Dev / tuning ────────────────────────────────────────────────────────────
SIM_MODE=0
SIM_RATE=90
SIM_BROADCAST=live
SIM_FLAP=0
VIEWER_POLL_MS=10000
