{
  "name": "market-bubble-live",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false server/index.ts",
    "dev:sim": "cross-env SIM_MODE=1 tsx watch --clear-screen=false server/index.ts",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/host-grotesk": "^5.2.8",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sirv": "^3.0.2",
    "tsx": "^4.22.4",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "typescript": "^5",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  }
}
